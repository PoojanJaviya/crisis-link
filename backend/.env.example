# Optional: override the path to your Firebase service account JSON key
# Default is ./firebase_key.json in the project root
FIREBASE_KEY_PATH=firebase_key.json

# JWT secret key — change this to a random secure string in production
JWT_SECRET=crisislink-dev-secret-change-in-production

# JWT token expiration in minutes (default: 1440 = 24 hours)
JWT_EXPIRE_MINUTES=1440
